{
  "name": "file-converter",
  "version": "1.0.0",
  "description": "Desktop file converter - Video, Audio, Images, Documents, Data",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "fluent-ffmpeg": "^2.1.3",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "sharp": "^0.33.0",
    "mammoth": "^1.7.0",
    "pdf-lib": "^1.17.1",
    "marked": "^12.0.0",
    "html-to-text": "^9.0.5",
    "csv-parse": "^5.5.6",
    "csv-stringify": "^6.4.6",
    "xml2js": "^0.6.2",
    "js-yaml": "^4.1.0",
    "zustand": "^4.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "lucide-react": "^0.344.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-vite": "^2.0.0",
    "electron-builder": "^24.0.0",
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/html-to-text": "^9.0.4",
    "@types/xml2js": "^0.4.14",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "@vitejs/plugin-react": "^4.2.0"
  },
  "build": {
    "appId": "com.fileconverter.app",
    "productName": "File Converter",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "asarUnpack": [
      "node_modules/@ffmpeg-installer/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
