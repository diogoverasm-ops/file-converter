{
  "name": "file-converter-mobile",
  "version": "1.0.0",
  "description": "Mobile PWA file converter with YouTube downloader",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host",
    "server": "node server/index.js",
    "start": "npm run build && npm run server"
  },
  "dependencies": {
